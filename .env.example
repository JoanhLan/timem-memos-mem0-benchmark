# TiMEM — register API key & account at https://api.timem.cloud
TIMEM_BASE_URL=https://api.timem.cloud
TIMEM_API_KEY=your_timem_api_key
TIMEM_ACCOUNT_ID=your_account_id

# Mem0 Platform
MEM0_API_KEY=your_mem0_api_key
MEM0_BASE_URL=https://api.mem0.ai
MEM0_INGEST_POLL_TIMEOUT_SEC=120
MEM0_SEARCH_THRESHOLD=0.0

# MemOS Cloud
MEMOS_API_KEY=your_memos_api_key
MEMOS_BASE_URL=https://memos.memtensor.cn/api/openmem/v1

# Judge (Volcengine ARK — OpenAI-compatible)
ARK_API_KEY=your_ark_api_key
ARK_API_BASE=https://ark.cn-beijing.volces.com/api/v3
JUDGE_MODEL=your_ark_endpoint_id
JUDGE_TEMPERATURE=0

# Benchmark
BENCHMARK_EXPERT_ID=benchmark
BENCHMARK_TOP_K=10
BENCHMARK_PERSONA_COUNT=10
BENCHMARK_BACKFILL_TIMEOUT_SEC=600
